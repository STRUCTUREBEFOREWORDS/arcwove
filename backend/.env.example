# ─────────────────────────────────────────────
# STRUCTURE Backend — Environment Variables
# Copy to .env and fill in real values
# ─────────────────────────────────────────────

# PostgreSQL (Conoha VPS)
DATABASE_URL=postgresql://user:password@localhost:5432/structure_db

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create monthly recurring prices in Stripe Dashboard)
STRIPE_PRICE_STARTER_JPY=price_...
STRIPE_PRICE_STARTER_USD=price_...
STRIPE_PRICE_STANDARD_JPY=price_...
STRIPE_PRICE_STANDARD_USD=price_...
STRIPE_PRICE_GROWTH_JPY=price_...
STRIPE_PRICE_GROWTH_USD=price_...

# Resend
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Frontend URL (GitHub Pages or Cloudflare Pages)
FRONTEND_URL=https://yoursite.pages.dev

# Admin API secret (generate with: openssl rand -hex 32)
ADMIN_SECRET=change_me_to_random_secret
